{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dosh",
  "version": "0.1.0",
  "identifier": "com.dosh.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Dosh",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:dosh.db"]
    }
  }
}
